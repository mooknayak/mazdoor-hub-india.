rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Workers: anyone can read (needed for public search).
    // A worker can create/update their own document, but CANNOT change their own
    // badge or tag fields — only an admin (listed in /admins) can change those.
    match /workers/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if isAdmin() ||
                       (request.auth != null && request.auth.uid == uid &&
                        request.resource.data.badge == resource.data.badge &&
                        request.resource.data.tag == resource.data.tag);
      allow delete: if false; // delete from Firebase Console if ever needed
    }

    // Admins: lists which UIDs are allowed to manage badges.
    // Add documents here manually from the Firebase Console:
    //   Collection: admins   Document ID: <admin's Firebase Auth UID>   Fields: { role: "admin" }
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // only editable from the Firebase Console, never from the app
    }
  }
}
